# Database (Neon / Supabase / Railway)
DATABASE_URL=postgresql://user:password@host:5432/toolverse

# JWT Secret (openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_here_change_me_in_production

# Email (Resend / SendGrid / Mailgun)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=your_email@resend.com
SMTP_PASSWORD=your_resend_api_key

# Frontend URL (CORS & email links için)
FRONTEND_URL=http://localhost:3000
# Production: https://toolverse-tau.vercel.app

# Server Port
PORT=4000
NODE_ENV=development
